<Window x:Class="SHNK_Booster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SHNK BOOSTER" Height="450" Width="350"
        Background="#0D0D11" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="Button" x:Key="MainBtnStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#00FF9D"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#00FF9D"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00FF9D"/>
                                <Setter Property="Foreground" Value="#0D0D11"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="TitleBarBtnStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="IconBtnStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1.0"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="White" BlurRadius="15" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#22c55e" BorderThickness="1" CornerRadius="8" Margin="10" Background="#0D0D11">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="SHNK BOOSTER v1.6" Foreground="#555" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>

                <Button Grid.Column="1" Name="MinimizeBtn" Content="—" Click="MinimizeBtn_Click" Style="{StaticResource TitleBarBtnStyle}" Foreground="#00E5FF"/>
                <Button Grid.Column="2" Name="CloseBtn" Content="✕" Click="CloseBtn_Click" Foreground="#FF003C">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TitleBarBtnStyle}">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF003C"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="260">

                <TextBlock Text="SHNK BOOSTER" Foreground="#00FF9D" FontSize="28" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00FF9D" BlurRadius="15" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Button Name="BtnGameLoop" Click="BtnGameLoop_Click" Style="{StaticResource IconBtnStyle}" Margin="0,0,15,0" Width="45" Height="45" ToolTip="تفعيل وضع GameLoop">
                        <Image Source="/Assets/gameloop.png" Stretch="Uniform"/>
                    </Button>

                    <Button Name="BtnLDPlayer" Click="BtnLDPlayer_Click" Style="{StaticResource IconBtnStyle}" Margin="15,0,0,0" Width="45" Height="45" ToolTip="تفعيل وضع LDPlayer">
                        <Image Source="/Assets/ldplayer.png" Stretch="Uniform"/>
                    </Button>
                </StackPanel>

                <Button Name="BoostBtn" Content="BOOST" Click="BoostBtn_Click" Style="{StaticResource MainBtnStyle}"/>

                <Button Name="TurboBtn" Content="TURBO" Click="TurboBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MainBtnStyle}">
                            <Setter Property="Foreground" Value="#FF003C"/>
                            <Setter Property="BorderBrush" Value="#FF003C"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF003C"/>
                                    <Setter Property="Foreground" Value="#0D0D11"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Name="UltraBtn" Content="ULTRA MODE 🚀" Click="UltraBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MainBtnStyle}">
                            <Setter Property="Foreground" Value="#FFD700"/>
                            <Setter Property="BorderBrush" Value="#FFD700"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFD700"/>
                                    <Setter Property="Foreground" Value="#0D0D11"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Name="RestoreBtn" Content="RESTORE" Click="RestoreBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MainBtnStyle}">
                            <Setter Property="Foreground" Value="#00E5FF"/>
                            <Setter Property="BorderBrush" Value="#00E5FF"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#00E5FF"/>
                                    <Setter Property="Foreground" Value="#0D0D11"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock Name="StatusText" Text="SYSTEM READY" Foreground="White" HorizontalAlignment="Center" Margin="0,20" FontWeight="SemiBold" FontSize="14"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Name="CpuText" Text="CPU: 0%" Foreground="#00FF9D" HorizontalAlignment="Center" Grid.Column="0" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Name="RamText" Text="RAM: 0%" Foreground="#00E5FF" HorizontalAlignment="Center" Grid.Column="1" FontSize="16" FontWeight="Bold"/>
                </Grid>

            </StackPanel>
        </Grid>
    </Border>
</Window>
